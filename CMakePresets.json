{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "PICO_SDK_PATH": "$penv{USERPROFILE}/.pico-sdk/sdk/2.2.0",
                "PICO_TOOLCHAIN_PATH": "$penv{USERPROFILE}/.pico-sdk/toolchain/14_2_Rel1",
                "PROJECT": "picoprobe",
                "PICOPROBE_VERSION_MAJOR": "2",
                "PICOPROBE_VERSION_MINOR": "2",
                "PICOPROBE_VERSION_PATCH": "4",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_MAKE_PROGRAM": "$penv{USERPROFILE}/.pico-sdk/ninja/v1.12.1/ninja"
            },
            "environment": {
                "PATH": "$penv{USERPROFILE}/.pico-sdk/toolchain/14_2_Rel1/bin;$penv{USERPROFILE}/.pico-sdk/cmake/v3.31.5/bin;$penv{PATH}"
            }
        },
        {
            "name": "pico-debug",
            "inherits": "default",
            "displayName": "Pico Debug",
            "description": "Debug build for Raspberry Pi Pico (RP2040)",
            "binaryDir": "${sourceDir}/_build/pico-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PICO_BOARD": "pico"
            }
        },
        {
            "name": "pico-release",
            "inherits": "default",
            "displayName": "Pico Release",
            "description": "Release build for Raspberry Pi Pico (RP2040)",
            "binaryDir": "${sourceDir}/_build/pico-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PICO_BOARD": "pico"
            }
        },
        {
            "name": "pico_w-debug",
            "inherits": "default",
            "displayName": "Pico W Debug",
            "description": "Debug build for Raspberry Pi Pico W (RP2040 + WiFi)",
            "binaryDir": "${sourceDir}/_build/pico_w-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PICO_BOARD": "pico_w"
            }
        },
        {
            "name": "pico_w-release",
            "inherits": "default",
            "displayName": "Pico W Release",
            "description": "Release build for Raspberry Pi Pico W (RP2040 + WiFi)",
            "binaryDir": "${sourceDir}/_build/pico_w-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PICO_BOARD": "pico_w"
            }
        },
        {
            "name": "pico_debug_probe-debug",
            "inherits": "default",
            "displayName": "Pico Debug Probe Debug",
            "description": "Debug build for Raspberry Pi Pico Debug Probe",
            "binaryDir": "${sourceDir}/_build/pico_debug_probe-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PICO_BOARD": "pico_debug_probe"
            }
        },
        {
            "name": "pico_debug_probe-release",
            "inherits": "default",
            "displayName": "Pico Debug Probe Release",
            "description": "Release build for Raspberry Pi Pico Debug Probe",
            "binaryDir": "${sourceDir}/_build/pico_debug_probe-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PICO_BOARD": "pico_debug_probe"
            }
        },
        {
            "name": "pico2-debug",
            "inherits": "default",
            "displayName": "Pico2 Debug",
            "description": "Debug build for Raspberry Pi Pico 2 (RP2350)",
            "binaryDir": "${sourceDir}/_build/pico2-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PICO_BOARD": "pico2"
            }
        },
        {
            "name": "pico2-release",
            "inherits": "default",
            "displayName": "Pico2 Release",
            "description": "Release build for Raspberry Pi Pico 2 (RP2350)",
            "binaryDir": "${sourceDir}/_build/pico2-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PICO_BOARD": "pico2"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "pico-debug-build",
            "configurePreset": "pico-debug"
        },
        {
            "name": "pico-release-build",
            "configurePreset": "pico-release"
        },
        {
            "name": "pico_w-debug-build",
            "configurePreset": "pico_w-debug"
        },
        {
            "name": "pico_w-release-build",
            "configurePreset": "pico_w-release"
        },
        {
            "name": "pico_debug_probe-debug-build",
            "configurePreset": "pico_debug_probe-debug"
        },
        {
            "name": "pico_debug_probe-release-build",
            "configurePreset": "pico_debug_probe-release"
        },
        {
            "name": "pico2-debug-build",
            "configurePreset": "pico2-debug"
        },
        {
            "name": "pico2-release-build",
            "configurePreset": "pico2-release"
        }
    ]
}
